# YouTube Data API v3 key (required)
YOUTUBE_API_KEY=

# ISO 3166-1 alpha-2 region code
REGION_CODE=US

# Comma-separated category IDs (empty = all assignable categories)
CATEGORIES=

# Max videos per category (API max is 50)
MAX_RESULTS_PER_CATEGORY=50

# Output directories
OUTPUT_DIR=./data
LOG_DIR=./logs
CACHE_DIR=./cache

# Category list cache TTL in days
CATEGORIES_CACHE_TTL_DAYS=7

# Delete snapshots/reports older than this many days (0 = keep forever)
RETENTION_DAYS=90

# Timezone for Markdown report display
DISPLAY_TIMEZONE=UTC

# Custom keyword-based categories (format: Name:kw1|kw2|kw3;Name2:kw4|kw5)
# Uses YouTube search API to find trending videos by keywords
# Leave empty to disable
CUSTOM_CATEGORIES=AI:artificial intelligence|AI|ChatGPT|LLM|机器学习

# Telegram notifications (optional, leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
